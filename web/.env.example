# lazarus-web environment (copy to .env for local runs)

# REQUIRED. If missing, the service hard-crashes at boot (Render deploy fails).
# This is failure-injection mode #1.
CRITICAL_CONFIG=super-secret-prod-token

# Failure-injection mode #2: when true, the app boots and serves traffic but
# GET /health returns 500. This is the primary demo path (rollback heals it).
BREAK_MODE=false

# How long since the last worker heartbeat before /health reports unhealthy.
WORKER_TIMEOUT_MS=30000

# Optional. Render injects RENDER_GIT_COMMIT automatically; locally you can pin one.
# APP_VERSION=1.4.2

# Port (Render injects PORT automatically).
PORT=3000
